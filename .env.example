# ── API Security ────────────────────────────────────────────────
API_SECRET_KEY=your_strong_random_secret_here
RATE_LIMIT_PER_MINUTE=10

# ── LLM via Groq ────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Web Search ──────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith ───────────────────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=BoardOfDirectors

# ── Notion ──────────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Model overrides (optional) ────────────────────────────────────
# All agents default to llama-3.3-70b-versatile on Groq. Every agent's
# model can be overridden independently — see console.groq.com/docs/models
# for the current list of model IDs available on your Groq account.
#
# CEO_MODEL=llama-3.3-70b-versatile
# RESEARCHER_MODEL=llama-3.3-70b-versatile
# CFO_MODEL=llama-3.3-70b-versatile
# CTO_MODEL=llama-3.3-70b-versatile
# CMO_MODEL=llama-3.3-70b-versatile
# SALES_MODEL=llama-3.3-70b-versatile
# COO_MODEL=llama-3.3-70b-versatile
# PM_MODEL=llama-3.3-70b-versatile
