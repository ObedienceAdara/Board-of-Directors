# ── API Security ───────────────────────────────────────────────
API_SECRET_KEY=your_strong_random_secret_here
RATE_LIMIT_PER_MINUTE=10

# ── LLM via Groq ─────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Web Search ─────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith ──────────────────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=BoardOfDirectors

# ── Notion ─────────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Model overrides (optional) ─────────────────────────────────
# Default is google/gemini-2.0-flash-exp:free for all agents (free tier).
# Uncomment and change to use paid models for production:
#
# CEO_MODEL=anthropic/claude-3.5-sonnet
# RESEARCHER_MODEL=google/gemini-2.0-flash-001
# CFO_MODEL=deepseek/deepseek-r1
# CTO_MODEL=deepseek/deepseek-r1
# CMO_MODEL=anthropic/claude-3.5-haiku
# SALES_MODEL=anthropic/claude-3.5-haiku
# COO_MODEL=google/gemini-2.0-flash-001
# PM_MODEL=meta-llama/llama-3.3-70b-instruct
